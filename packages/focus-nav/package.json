{
  "name": "@react-native-tvos/focus-nav",
  "version": "0.21.2-1",
  "description": "Spatial navigation primitives used by @rect-native-tvos/web-tv",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "lint": "eslint . --fix --max-warnings=0",
    "build": "webpack --config webpack.config.js && npm run generate-types",
    "dev": "webpack --config webpack.config.js --watch",
    "type-check": "tsc --noEmit",
    "generate-types": "tsc --skipLibCheck --strictNullChecks false --emitDeclarationOnly"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/eslint": "9.6.1",
    "@types/lodash": "^4.14.198",
    "ts-loader": "^9.2.6",
    "typescript": "^5.9.3",
    "webpack": "^5.76.0"
  },
  "author": "Yusuf YILDIRIM",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/yusufyildirim/react-native-web-tv.git"
  },
  "keywords": [
    "focus",
    "navigation",
    "react",
    "react-native",
    "tv"
  ]
}
